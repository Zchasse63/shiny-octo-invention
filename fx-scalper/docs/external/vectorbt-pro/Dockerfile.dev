FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

ENV PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    UV_SYSTEM_PYTHON=1 \
    DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends build-essential cmake git wget sudo vim && \
    rm -rf /var/lib/apt/lists/*

COPY ./vectorbtpro ./vectorbtpro
COPY pyproject.toml LICENSE README.md ./

RUN uv pip install --system --no-cache-dir "universal-portfolios" || true
RUN uv pip install --system --no-cache-dir "smartmoneyconcepts>0.0.10" || true
RUN uv pip install --system --no-cache-dir "arcticdb" || true

RUN uv pip install --system --no-cache-dir ".[all-stable]"

RUN groupadd -g 1000 devuser && \
    useradd -u 1000 -g devuser -m -s /bin/bash devuser && \
    echo 'devuser ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers && \
    install -d -o devuser -g devuser /workspace

USER devuser
WORKDIR /workspace
ENTRYPOINT ["bash"]
