# OANDA credentials — copy to .env and fill in real values.
# Never commit .env.

# Token from OANDA dashboard → Manage API Access
OANDA_API_KEY=your-oanda-api-token-here

# Account ID, format: 001-001-XXXXXXX-001
OANDA_ACCOUNT_ID=001-001-0000000-001

# "practice" or "live"
OANDA_ENVIRONMENT=practice

# Optional: override log level. One of: TRACE, DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: override SQLite journal path (default: ./journal.db)
JOURNAL_DB_PATH=journal.db
