# fx-scalper secrets template — copy to .env and fill in.
# .env is gitignored. Never commit secrets.

# --- OANDA (required for paper/live trading, Week 2+) ---
# Token from OANDA dashboard → Manage API Access
OANDA_API_KEY=your-oanda-api-token-here
# Account ID, format: 001-001-XXXXXXX-001
OANDA_ACCOUNT_ID=001-001-0000000-001
# "practice" or "live"
OANDA_ENVIRONMENT=practice

# --- LLM provider keys (optional, Tier 2 research-time only) ---
# Used by vbt.chat / vbt.search in the Knowledge module.
# Pick one provider; Anthropic is recommended for code-style queries.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# GEMINI_API_KEY=

# --- GitHub token for vbtpro docs fetch (Tier 2 only) ---
# Only needed when vbt.chat / vbt.search first builds the docs corpus.
GITHUB_TOKEN=

# --- Logging + journal ---
LOG_LEVEL=INFO
JOURNAL_DB_PATH=journal.db
